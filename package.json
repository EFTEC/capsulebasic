{
  "publisher": "jorge-castro-c",
  "name": "capsulebasic",
  "displayName": "CapsuleBasic Syntax Highlighting",
  "description": "Syntax highlighting for CapsuleBasic, a language that uses <| and |> delimiters",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.50.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EFTEC/capsulebasic"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "cbasic",
        "aliases": ["CapsuleBasic", "capsulebasic"],
        "extensions": [".cbasic"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cbasic",
        "scopeName": "source.cbasic",
        "path": "./syntaxes/cbasic.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "CapsuleBasic Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/cbasic-color-theme.json"
      }
    ]
  }
}
